{
  "name": "project-memory-ai",
  "publisher": "project-memory",
  "displayName": "Project Memory AI",
  "description": "AI-powered developer context recovery",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "projectMemory.showPanel",
        "title": "Project Memory AI: Show Panel"
      },
      {
        "command": "projectMemory.refresh",
        "title": "Project Memory AI: Refresh Summary"
      },
      {
        "command": "projectMemory.setGroqKey",
        "title": "Project Memory AI: Set Groq API Key"
      },
      {
        "command": "projectMemory.clearMemory",
        "title": "Project Memory AI: Clear Memory"
      },
      {
        "command": "projectMemory.generateCommit",
        "title": "Project Memory AI: Generate Commit Message"
      },
      {
        "command": "projectMemory.showHealthScore",
        "title": "Project Memory AI: Show Health Score"
      },
      {
        "command": "projectMemory.generateStandup",
        "title": "Project Memory AI: Generate Standup"
      },
      {
        "command": "projectMemory.detectConflicts",
        "title": "Project Memory AI: Detect Merge Conflicts"
      },
      {
        "command": "projectMemory.analyzeConflict",
        "title": "Project Memory AI: Analyze Conflict"
      },
      {
        "command": "projectMemory.resolveConflict",
        "title": "Project Memory AI: Resolve Conflict"
      },
      {
        "command": "projectMemory.resolveAllConflicts",
        "title": "Project Memory AI: Resolve All Conflicts"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-memory-ai-sidebar",
          "title": "Project Memory AI",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "project-memory-ai-sidebar": [
        {
          "type": "webview",
          "id": "projectMemoryPanel",
          "name": "Project Memory"
        }
      ]
    },
    "configuration": {
      "title": "Project Memory AI",
      "properties": {
        "projectMemory.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API Key (Placeholder only, actual key stored securely via set command)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "simple-git": "^3.24.0"
  }
}
